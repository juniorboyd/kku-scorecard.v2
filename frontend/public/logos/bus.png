                    <a href="javascript:void(0)" onclick="changeLanguage('en')">
                        | EN                                            </a>
                </li>
                        </ul>
                <script>
            function toggleDropdown() {
                document.querySelector('.dropdown-list').style.display =
                    document.querySelector('.dropdown-list').style.display === 'block' ? 'none' : 'block';
            }

            function changeLanguage(lang) {
                // ÓĖ¬Ó╣łÓĖćÓĖäÓĖ│ÓĖéÓĖŁ AJAX Ó╣ĆÓĖ×ÓĖĘÓ╣łÓĖŁÓ╣ĆÓĖøÓĖźÓĖĄÓ╣łÓĖóÓĖÖÓ╣üÓĖøÓĖźÓĖćÓĖäÓĖĖÓĖüÓĖüÓĖĄÓ╣ē
                jQuery.post({
                    url: EM['ajaxurl'], // WordPress AJAX URL
                    data: {
                        action: 'set_language_cookie',
                        lang: lang
                    },
                    success: function(response) {
                        if (response.success) {
                            // ÓĖ¢Ó╣ēÓĖ▓ÓĖüÓĖ▓ÓĖŻÓĖĢÓĖ▒Ó╣ēÓĖćÓĖäÓĖĖÓĖüÓĖüÓĖĄÓ╣ēÓĖ¬ÓĖ│Ó╣ĆÓĖŻÓ╣ćÓĖł, Ó╣ĆÓĖøÓĖźÓĖĄÓ╣łÓĖóÓĖÖ URL Ó╣éÓĖöÓĖóÓ╣ĆÓĖ×ÓĖ┤Ó╣łÓĖĪ ?lang=th
                            var currentUrl = window.location.href;
                            // var newUrl = new URL(currentUrl);

                            // // ÓĖ¢Ó╣ēÓĖ▓ URL ÓĖĪÓĖĄÓĖ×ÓĖ▓ÓĖŻÓĖ▓ÓĖĪÓĖ┤Ó╣ĆÓĖĢÓĖŁÓĖŻÓ╣ī lang ÓĖŁÓĖóÓĖ╣Ó╣łÓ╣üÓĖźÓ╣ēÓĖ¦, Ó╣āÓĖ½Ó╣ēÓ╣ĆÓĖøÓĖźÓĖĄÓ╣łÓĖóÓĖÖÓĖäÓ╣łÓĖ▓ lang
                            // if (newUrl.searchParams.has('lang')) {
                            //     newUrl.searchParams.set('lang', lang);
                            // } else {
                            //     // ÓĖ¢Ó╣ēÓĖ▓Ó╣äÓĖĪÓ╣łÓĖĪÓĖĄÓĖ×ÓĖ▓ÓĖŻÓĖ▓ÓĖĪÓĖ┤Ó╣ĆÓĖĢÓĖŁÓĖŻÓ╣ī lang, Ó╣āÓĖ½Ó╣ēÓ╣ĆÓĖ×ÓĖ┤Ó╣łÓĖĪ ?lang=th
                            //     newUrl.searchParams.append('lang', lang);
                            // }

                            // Ó╣éÓĖ½ÓĖźÓĖöÓĖ½ÓĖÖÓ╣ēÓĖ▓Ó╣āÓĖ½ÓĖĪÓ╣łÓĖöÓ╣ēÓĖ¦ÓĖó URL ÓĖŚÓĖĄÓ╣łÓ╣ĆÓĖ×ÓĖ┤Ó╣łÓĖĪ lang
                            window.location.href = currentUrl.toString();
                            console.log("Language changed to", lang);
                        }
                    }
                });
            }

            document.addEventListener('click', function(event) {
                if (!event.target.closest('.custom-select')) {
                    document.querySelector('.dropdown-list').style.display = 'none';
                }
            });
        </script>
