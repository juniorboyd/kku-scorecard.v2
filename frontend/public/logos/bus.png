					                <style>
            .list-lang2>li>a {
                color: #333;
            }
            ul.list-lang2 {
                padding-right: 5px;
                padding-top: 5px;
            }
        </style>
        <ul class="list-lang2" style="list-style-type: none;">
                            <li style="float: left;padding-left: 5px;">
                    <a href="javascript:void(0)" onclick="changeLanguage('th')">
                        TH                                            </a>
                </li>
