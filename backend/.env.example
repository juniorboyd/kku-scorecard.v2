DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/kku_scorecard?schema=public"
PORT=4000
NODE_ENV=development

# Auth: DEV or SSO
AUTH_MODE=DEV
DEV_ROLE=ADMIN      # ADMIN | ANALYST | VIEWER  (default: ADMIN)
ADMIN_EMAILS=admin1@kkumail.com,admin2@kkumail.com
SESSION_SECRET=change-this-secret-in-production
APP_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# SSO (required when AUTH_MODE=SSO)
SSO_APP_ID=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_LOGIN_URL=https://sso-uat-web.kku.ac.th/login
SSO_LOGOUT_URL=https://sso-uat-web.kku.ac.th/logout
SSO_TOKEN_API=https://sso-uat-api.kku.ac.th/auth.token
SSO_PROFILE_API=https://sso-uat-api.kku.ac.th/user.profile
SSO_STATUS_API=https://sso-uat-api.kku.ac.th/auth.status
SSO_REDIRECT_URL=https://localhost:4333/callback

# Encryption key for sensitive settings at rest (32 bytes / 64 hex chars). Required.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# SecurityScorecard
SECURITY_SCORECARD_API_URL=https://api.securityscorecard.io/companies/kku.ac.th/issues
SECURITY_SCORECARD_API_KEY=vZVpopKjJ4YQurqGZ6p6YNBNOvwT
SECURITY_SCORECARD_API_KEY_HEADER=Authorization
SECURITY_SCORECARD_COMPANY_DOMAIN=kku.ac.th
SECURITY_SCORECARD_SCORE_HISTORY_URL=

# Python
PYTHON_EXECUTABLE=python
